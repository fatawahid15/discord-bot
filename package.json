{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "A stateless Discord entertainment and Node.js music bot.",
  "main": "dist/index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "deploy": "npm run build && node dist/deploy-commands.js",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/builders": "^1.14.1",
    "@discordjs/rest": "^2.6.2",
    "@snazzah/davey": "^0.1.12",
    "discord-api-types": "^0.38.50",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "mediaplex": "^1.0.0",
    "undici": "^8.7.0",
    "youtube-dl-exec": "^3.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
